{
  "$schema": "https://opencode.ai/config.json",

  "mcp": {
    "lean-ctx": {
      "type": "local",
      "command": ["/opt/homebrew/bin/lean-ctx"],
      "enabled": true
    }
  },

  "provider": {
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local vLLM (DGX)",
      "options": {
        "baseURL": "http://<dgx-host>.<your-tailnet>.ts.net:9000/v1",
        "apiKey": "<vllm-api-key>"
      },
      "models": {
        "Qwen/Qwen3-Coder-Next-FP8": {
          "name": "Qwen3-Coder-Next (FP8)",
          "tools": true
        }
      }
    }
  },

  "model": "vllm/Qwen/Qwen3-Coder-Next-FP8",
  "small_model": "vllm/Qwen/Qwen3-Coder-Next-FP8"
}
