# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp

# Node
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Secrets — NEVER commit .env files
.env
.env.local
.env.*.local
secrets/
*.key
*.pem

# Backups produced by config edits — keep templates only
*.bak
*.bak.*

# Local data / volumes (only under infra/* compose stacks; other dirs may
# have legitimate tracked data/ — e.g. provider-bakeoff/data/).
infra/**/data/
infra/**/volumes/
*.local.yml

# Build artifacts
dist/
build/
*.egg-info/

# MkDocs build output
site/

# lean-ctx runtime cache
.lean-ctx/

# workstation/ — never commit filled secret config, only *.example
workstation/claude/settings.json
workstation/config/opencode/opencode.json

# backup files with non-standard suffixes (compose snapshots etc.)
*.bak*
*-bak
