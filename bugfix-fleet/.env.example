# bugfix-fleet MVP — copy to .env (gitignored). Real values via sops on the mini.

# --- Target repo (the sandbox for the MVP) ---
TARGET_OWNER=chipi
TARGET_REPO=bugfix-fleet-sandbox
REPO_CHECKOUT=/Users/you/.bugfix-fleet/bugfix-fleet-sandbox   # local clone the worktrees branch from

# --- Your GitHub App (create it; download the .pem) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=       # PEM contents; \n-escaped single line is OK
GITHUB_APP_INSTALLATION_ID=   # from installing the App on the target repo
GITHUB_WEBHOOK_SECRET=

# --- Workers (cheap models via OpenRouter) ---
HARNESS=opencode              # bake-off flip: pi | opencode
OPENROUTER_API_KEY=
TRIAGE_MODEL=deepseek/deepseek-v4-flash
FIX_MODEL=deepseek/deepseek-v4-pro
OPENCODE_SERVER_URL=http://127.0.0.1:4096   # `opencode serve`

# --- Observability (self-hosted Langfuse on the homelab) ---
LANGFUSE_HOST=http://homelab:4000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
