# Repo-root master .env template — copy to .env, fill in secrets.
#     cp .env.example .env      # then set HF_TOKEN
#
# Read directly by the coder-next and openwebui stacks (and any stack whose
# env_file points at the repo root). Per-stack overrides live in each stack's
# own .env.example (infra/vllm/*/.env.example, infra/observability/.env.example).

# HuggingFace token — required for gated model downloads. The one real secret
# here; leave everything else at its default unless your host layout differs.
HF_TOKEN=

# vLLM API key — clients pass this as `Authorization: Bearer <key>`.
# Single-operator dummy; pick anything memorable and keep clients in sync.
VLLM_API_KEY=buddy-is-the-king

# Ports (homelab convention: serving vLLM on 9000, Open WebUI on 3000).
VLLM_PORT=9000
OPENWEBUI_PORT=3000

# GPU memory utilization for the coder-next serving vLLM. Hard ceiling on GB10
# unified memory is 0.78; 0.92 OOM-crashes — do not exceed 0.78.
VLLM_GPU_MEM_UTIL=0.75

# Model cache paths on the host. Mounted 1:1 into the containers so HF paths
# resolve identically inside and out; shared across all vLLM stacks.
HF_HOME=/opt/llm-models/huggingface
VLLM_CACHE_PATH=/opt/llm-models/vllm-cache
