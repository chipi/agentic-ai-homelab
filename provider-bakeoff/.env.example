# Provider API keys — copy to .env (gitignored) and fill what you have.
# The bake-off skips any provider whose key is unset; you can run with
# whichever subset you've signed up for.
#
# Cost budget for a full sweep (10 items × 2 tasks × ~100-200 output tokens):
#   ~$2-5 total across all providers below.

# ─── United States 🇺🇸 ─────────────────────────────────────────────────
# Anthropic — claude-sonnet-4-6 by default
#   Get one: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI — gpt-5-mini by default
#   Get one: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Google — gemini-2.5-flash by default
#   Get one: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# xAI Grok — grok-2-latest by default
#   Get one: https://console.x.ai/
XAI_API_KEY=xai-...

# ─── Europe 🇪🇺 ────────────────────────────────────────────────────────
# Mistral AI (France) — mistral-small-latest by default
#   Get one: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=...

# Hugging Face Inference (France) — routes to open-weight models like
# Llama 3.3 70B, Mixtral, Qwen open releases, etc.
#   Get one: https://huggingface.co/settings/tokens (Read scope is enough)
HF_TOKEN=hf_...

# ─── China 🇨🇳 ─────────────────────────────────────────────────────────
# DeepSeek — deepseek-chat by default
#   Get one: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# Alibaba Qwen via DashScope — qwen-plus by default
#   Get one (international): https://bailian.console.aliyun.com/?apiKey=1
#   Get one (mainland CN):    https://dashscope.console.aliyun.com/apiKey
# If you're on the mainland CN endpoint, also set:
#   DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-...

# Moonshot Kimi — kimi-k2-0905-preview by default
#   Get one (international): https://platform.moonshot.ai/
#   Get one (mainland CN):   https://platform.moonshot.cn/
# If you're on the mainland CN endpoint, also set:
#   MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=sk-...

# ─── Local self-hosted 🏠 ──────────────────────────────────────────────
# Local vLLM running on the operator's tailnet (or any OpenAI-compatible
# self-hosted endpoint). Defaults match infra/vllm/docker-compose.yml.
# Override URL and model to point at your own setup.
LOCAL_VLLM_URL=http://localhost:9000/v1
LOCAL_VLLM_API_KEY=buddy-is-the-king
LOCAL_VLLM_MODEL=Qwen/Qwen3-Coder-Next-FP8
