# GlitchTip — copy to .env (gitignored). Runs on ONE host (DGX now, Mac mini later).

# --- Bind ---------------------------------------------------------------
# This host's Tailscale IP (100.x.y.z) so the UI + ingest are on the tailnet,
# never public. 127.0.0.1 for a local smoke test. GLITCHTIP_PORT needs its own
# tailnet ACL grant (the ACL is a per-port allowlist).
GLITCHTIP_LISTEN=127.0.0.1
GLITCHTIP_PORT=8090

# External URL apps + browser use to reach GlitchTip. MUST match how it's
# actually reached (drives DSNs, links, CSRF). On the tailnet:
#   http://100.x.y.z:8090
GLITCHTIP_DOMAIN=http://127.0.0.1:8090

# --- Secrets (generate strong values) -----------------------------------
POSTGRES_PASSWORD=
SECRET_KEY=

# --- First-run admin (createsuperuser --noinput) ------------------------
DJANGO_SUPERUSER_EMAIL=admin@homelab.local
DJANGO_SUPERUSER_PASSWORD=

# --- Misc ---------------------------------------------------------------
# Registration closed (tailnet-private); the superuser above is the first user.
ENABLE_OPEN_USER_REGISTRATION=false
DEFAULT_FROM_EMAIL=glitchtip@homelab.local
# Outbound mail off by default (console). For real notifications:
# EMAIL_URL=smtp://user:pass@smtp-host:587
