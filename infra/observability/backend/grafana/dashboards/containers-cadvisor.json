{
  "uid": "containers-cadvisor",
  "title": "Containers \u2014 cAdvisor",
  "tags": [
    "containers",
    "cadvisor",
    "docker"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Containers seen",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "count(count by (id)(container_memory_working_set_bytes{id=~\".*docker-.*\"}))",
          "legendFormat": "",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Total container memory",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "sum(container_memory_working_set_bytes{id=~\".*docker-.*\"})",
          "legendFormat": "",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Top containers by memory",
      "type": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "topk(15, label_replace(sum by (id) (container_memory_working_set_bytes{id=~\".*docker-.*\"}), \"container\", \"$1\", \"id\", \".*docker-(.{12}).*\"))",
          "legendFormat": "{{container}}",
          "instant": true
        }
      ],
      "targets": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "CPU by container (cores)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "label_replace(sum by (id) (rate(container_cpu_usage_seconds_total{id=~\".*docker-.*\"}[$__rate_interval])), \"container\", \"$1\", \"id\", \".*docker-(.{12}).*\")",
          "legendFormat": "{{container}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Memory working set",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "label_replace(sum by (id) (container_memory_working_set_bytes{id=~\".*docker-.*\"}), \"container\", \"$1\", \"id\", \".*docker-(.{12}).*\")",
          "legendFormat": "{{container}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Network RX (B/s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "label_replace(sum by (id) (rate(container_network_receive_bytes_total{id=~\".*docker-.*\"}[$__rate_interval])), \"container\", \"$1\", \"id\", \".*docker-(.{12}).*\")",
          "legendFormat": "{{container}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Network TX (B/s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "label_replace(sum by (id) (rate(container_network_transmit_bytes_total{id=~\".*docker-.*\"}[$__rate_interval])), \"container\", \"$1\", \"id\", \".*docker-(.{12}).*\")",
          "legendFormat": "{{container}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "stacking": {
              "mode": "none"
            }
          },
          "unit": "Bps"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Note",
      "type": "text",
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "gridPos": [],
      "targets": {
        "mode": "markdown",
        "content": "Container names show as short Docker IDs because cAdvisor isn't resolving Docker metadata on this host \u2014 the `name` label is absent from the kept metrics. Friendly names would need a cAdvisor collector fix. For name-based views, use the **Logs \u2014 Overview** dashboard (VictoriaLogs has the `container` label)."
      },
      "options": {},
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ]
}