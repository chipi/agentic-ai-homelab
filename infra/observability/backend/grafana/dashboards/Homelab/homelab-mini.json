        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "node_memory_inactive_bytes{instance=\"homelab\"}",
          "legendFormat": "inactive",
          "instant": true
