        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "node_memory_compressed_bytes{instance=\"homelab\"}",
          "legendFormat": "compressed",
          "instant": true
