      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "sum(rate(node_network_receive_bytes_total{instance=\"homelab\"}[$__rate_interval]))",
