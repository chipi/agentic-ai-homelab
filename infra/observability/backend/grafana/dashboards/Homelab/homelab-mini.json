          },
          "expr": "100*node_filesystem_avail_bytes{instance=\"homelab\",mountpoint=~\"/|/System/Volumes/Data\"}/node_filesystem_size_bytes{instance=\"homelab\",mountpoint=~\"/|/System/Volumes/Data\"}",
