{
  "uid": "dgx-services",
  "id": null,
  "title": "DGX — Services",
  "tags": ["dgx", "homelab", "services"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "FastAPI service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": { "query": "label_values(http_requests_total{job=~\"pyannote-app|moss-app\"}, job)", "refId": "svc" },
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "DGX app health (up)",
      "gridPos": { "h": 4, "w": 10, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "dgx_service_up", "legendFormat": "{{service}}", "instant": true } ]
    },
    {
      "id": 2, "type": "stat", "title": "GPU util",
      "gridPos": { "h": 4, "w": 7, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "avg(DCGM_FI_DEV_GPU_UTIL)", "legendFormat": "gpu" } ]
    },
    {
      "id": 3, "type": "stat", "title": "GPU mem used",
      "gridPos": { "h": 4, "w": 7, "x": 17, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "sum(DCGM_FI_DEV_FB_USED)", "legendFormat": "used" } ]
    },
    {
      "id": 4, "type": "timeseries", "title": "FastAPI request rate ($service)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "sum by (job) (rate(http_requests_total{job=~\"$service\"}[$__rate_interval]))", "legendFormat": "{{job}}" } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "FastAPI p95 latency ($service)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket{job=~\"$service\"}[$__rate_interval])))", "legendFormat": "{{job}}" } ]
    },
    {
      "id": 6, "type": "timeseries", "title": "vLLM autoresearch — running / waiting",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 20, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "sum(vllm:num_requests_running{job=\"vllm-autoresearch\"})", "legendFormat": "running" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "sum(vllm:num_requests_waiting{job=\"vllm-autoresearch\"})", "legendFormat": "waiting" }
      ]
    },
    {
      "id": 7, "type": "stat", "title": "Support DBs (up)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "pg_up", "legendFormat": "{{service}} pg", "instant": true },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "redis_up", "legendFormat": "{{service}} redis", "instant": true }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Postgres connections",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "victoriametrics" }, "expr": "sum by (service) (pg_stat_database_numbackends)", "legendFormat": "{{service}}" } ]
    }
  ]
}
