# Copy to .env (gitignored). The BACKEND runs on ONE host at a time
# (DGX now, Mac mini later). Collectors have their own .env in ../ .

# --- Bind addresses -----------------------------------------------------
# Set these to THIS host's Tailscale IP (100.x.y.z) so ingest + the Grafana
# UI are reachable across the tailnet but never on a public interface.
# Leave at 127.0.0.1 for a local-only first boot / smoke test.
VM_LISTEN=127.0.0.1
VLOGS_LISTEN=127.0.0.1
VTRACES_LISTEN=127.0.0.1
GRAFANA_LISTEN=127.0.0.1

# --- VictoriaMetrics (metrics) ------------------------------------------
VM_RETENTION=6                 # retention period in months

# --- VictoriaLogs (logs) ------------------------------------------------
VLOGS_RETENTION=30d            # retention as a duration (e.g. 7d, 30d, 1y)

# --- Grafana admin ------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=        # REQUIRED — set a strong value; compose refuses to start empty

# --- Alert notification channels (generic / add-later) ------------------
# Alert RULES + ROUTING are provisioned as code (grafana/provisioning/alerting/).
# The CHANNELS below are pluggable — a channel ships as an inert placeholder and
# goes live the moment you set its var here + `docker compose up -d grafana`.
# Routing (policies.yaml): everything -> default; severity=critical -> also GlitchTip.
#
# Slack: paste an incoming-webhook URL. To make Slack the day-to-day channel,
# point the `default` route at it (policies.yaml) or set email too.
ALERT_SLACK_WEBHOOK_URL=        # https://hooks.slack.com/services/T.../B.../xxxx
# GlitchTip: the webhook that opens an issue (severity=critical only). Its HOST is
# a backend reference — use the host GlitchTip runs on: DGX (100.69.49.126:8090)
# now, `homelab:8090` after migration. (Grafana + GlitchTip are separate compose
# stacks, so this goes over the tailnet, not an internal bridge.)
ALERT_GLITCHTIP_WEBHOOK_URL=    # http://<host>:8090/api/.../webhook
# Email: needs the SMTP block below AND a recipient.
ALERT_EMAIL_TO=                 # ops@yourdomain (comma-separated for many)

# Email transport — only if you wire the email channel. Off by default.
GF_SMTP_ENABLED=false
GF_SMTP_HOST=                   # smtp.example.com:587
GF_SMTP_USER=
GF_SMTP_PASSWORD=
GF_SMTP_FROM_ADDRESS=           # defaults to admin@grafana.localhost if unset
