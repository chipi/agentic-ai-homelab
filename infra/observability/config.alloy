// =============================================================================
// Grafana Alloy — unified DGX-class homelab observability.
// Scrapes host + GPU + containers + LLM serving endpoints on localhost.
// Forwards to Grafana Cloud Prometheus via prometheus.remote_write.
// =============================================================================

// ---------- HOST: CPU, memory, disk, network, filesystem ----------
// disable_collectors: drop collectors that produce zero useful series on
// this homelab (no NFS, no IPVS, no tape drives, no bonded interfaces,
// no Infiniband, no btrfs). Saves ~50-150 active series with zero info
// loss for dashboards 1860 / similar. Dashboard 1860 still has every-
// thing it needs (cpu, diskstats, filesystem, loadavg, meminfo, netdev,
// netstat, sockstat, vmstat, time, uname, stat, hwmon, thermal_zone, edac).
prometheus.exporter.unix "host" {
  rootfs_path        = "/rootfs"
  disable_collectors = [
    "mountstats", "infiniband", "nfs", "nfsd", "tapestats",
    "ipvs", "bonding", "btrfs",
  ]
}

prometheus.scrape "host" {
  targets         = prometheus.exporter.unix.host.targets
  forward_to      = [prometheus.remote_write.grafana_cloud.receiver]
  job_name        = "node"
  scrape_interval = "30s"
}

// ---------- GPU: NVIDIA DCGM ----------
prometheus.scrape "dcgm" {
  targets         = [{ __address__ = "localhost:9400", instance = coalesce(sys.env("HOMELAB_INSTANCE"), "homelab-1") }]
  forward_to      = [prometheus.remote_write.grafana_cloud.receiver]
  job_name        = "dcgm"
  scrape_interval = "15s"
}

// ---------- CONTAINERS: cAdvisor ----------
// Keep-list via a chained prometheus.relabel component (Alloy's idiom —
// inline metric_relabel_config is the classic-Prometheus form and isn't
// a valid block here). cAdvisor exports ~95 metric names with per-
// container × per-device × per-interface cardinality (~4.3k series with
// 10 containers running). Dashboard 893 uses ~15 metric names. Keeping
// just those cuts cAdvisor from ~4,363 → ~1,582 series (~64% drop) with
// no visible difference in the dashboard. Verified empirically on DGX.
prometheus.scrape "cadvisor" {
  targets         = [{ __address__ = "localhost:8080", instance = coalesce(sys.env("HOMELAB_INSTANCE"), "homelab-1") }]
  forward_to      = [prometheus.relabel.cadvisor_keep.receiver]
  job_name        = "cadvisor"
  scrape_interval = "30s"
}

prometheus.relabel "cadvisor_keep" {
  forward_to = [prometheus.remote_write.grafana_cloud.receiver]
  rule {
    source_labels = ["__name__"]
    regex         = "container_cpu_usage_seconds_total|container_memory_(usage|working_set|max_usage|rss)_bytes|container_fs_(reads|writes)_bytes_total|container_network_(receive|transmit)_bytes_total|container_oom_events_total|container_start_time_seconds|container_last_seen|container_spec_memory_limit_bytes|container_spec_cpu_(quota|period)|container_tasks_state|machine_cpu_cores|machine_memory_bytes"
    action        = "keep"
  }
}

// ---------- LLM SERVING: vLLM coder model on port 9000 ----------
// vLLM exposes Prometheus metrics natively at /metrics. model_name label is set
// per-metric so dashboards can split by model.
prometheus.scrape "vllm" {
  targets         = [{ __address__ = "localhost:9000", instance = coalesce(sys.env("HOMELAB_INSTANCE"), "homelab-1") }]
  forward_to      = [prometheus.remote_write.grafana_cloud.receiver]
  job_name        = "vllm"
  scrape_interval = "15s"
}

// ---------- LLM SERVING: Ollama via NorskHelsenett exporter ----------
// Level 1 (passive) — exporter polls /api/ps independently. Returns model
// inventory + RAM metrics without any client retargeting.
prometheus.scrape "ollama" {
  targets         = [{ __address__ = "localhost:9778", instance = coalesce(sys.env("HOMELAB_INSTANCE"), "homelab-1") }]
  forward_to      = [prometheus.remote_write.grafana_cloud.receiver]
  job_name        = "ollama"
  scrape_interval = "15s"
}

// ---------- Optional: secondary vLLM (e.g., autoresearch eval) on port 8003 ----------
// Uncomment if running a second vLLM compose for sweeps / evals.
// prometheus.scrape "vllm_secondary" {
//   targets         = [{ __address__ = "localhost:8003", instance = coalesce(sys.env("HOMELAB_INSTANCE"), "homelab-1") }]
//   forward_to      = [prometheus.remote_write.grafana_cloud.receiver]
//   job_name        = "vllm-secondary"
//   scrape_interval = "15s"
// }

// ---------- Optional: project FastAPI servers with prometheus_client wired in ----------
// Uncomment + adjust ports/services after wiring prometheus_client into your app.
// prometheus.scrape "fastapi" {
//   targets = [
//     { __address__ = "localhost:8001", instance = coalesce(sys.env("HOMELAB_INSTANCE"), "homelab-1"), service = "service-a" },
//     { __address__ = "localhost:8002", instance = coalesce(sys.env("HOMELAB_INSTANCE"), "homelab-1"), service = "service-b" },
//   ]
//   forward_to      = [prometheus.remote_write.grafana_cloud.receiver]
//   job_name        = "fastapi"
//   scrape_interval = "30s"
// }

// ---------- PUSH to Grafana Cloud ----------
prometheus.remote_write "grafana_cloud" {
  endpoint {
    url = sys.env("GRAFANA_CLOUD_PROM_URL")
    basic_auth {
      username = sys.env("GRAFANA_CLOUD_PROM_USERNAME")
      password = sys.env("GRAFANA_CLOUD_PROM_API_KEY")
    }
  }

  // Logical group label, set per-deploy via .env (HOMELAB_CLUSTER).
  // Useful when multiple stacks push to the same Grafana Cloud endpoint.
  external_labels = {
    cluster = coalesce(sys.env("HOMELAB_CLUSTER"), "default"),
  }
}
