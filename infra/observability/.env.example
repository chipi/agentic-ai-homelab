# Copy to .env (gitignored). Pick ONE remote_write target:
#
# A) Self-hosted VictoriaMetrics (infra/observability/backend/) — RECOMMENDED.
#    Point REMOTE_WRITE_URL at the backend host's Tailscale IP. No auth needed
#    on the tailnet; the GRAFANA_CLOUD_PROM_* vars below are ignored but Alloy
#    still reads them, so leave them as any dummy value.
# REMOTE_WRITE_URL=http://100.x.y.z:8428/api/v1/write
#
# B) Grafana Cloud — leave REMOTE_WRITE_URL unset and fill these from:
#    Grafana Cloud UI → Connections → Hosted Prometheus metrics (endpoint URL,
#    username = instance ID, API token).
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-YY-NN.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USERNAME=1234567
GRAFANA_CLOUD_PROM_API_KEY=glc_eyJxxxxxxxxx

# Per-deploy identity labels (applied to every metric pushed):
#   HOMELAB_INSTANCE — per-target instance label (e.g., your host name)
#   HOMELAB_CLUSTER  — logical group label (filter on this in Grafana queries)
HOMELAB_INSTANCE=homelab-1
HOMELAB_CLUSTER=homelab
