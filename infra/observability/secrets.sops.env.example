# Template for the sops-encrypted observability secrets.
#
# Create the REAL file (fresh, strong values) then encrypt it:
#   cp secrets.sops.env.example secrets.sops.env
#   # fill every value below, e.g.:
#   #   openssl rand -hex 16   (passwords)   openssl rand -hex 32   (keys)
#   #   ENCRYPTION_KEY must be exactly 64 hex chars
#   #   *_PUBLIC_KEY / *_SECRET_KEY:  pk-lf-$(uuidgen|tr A-Z a-z) / sk-lf-…
#   sops -e -i secrets.sops.env       # encrypts in place; commit the result
#
# bootstrap.sh decrypts this and assembles each stack's .env. Non-secret,
# host-specific values (tailnet IP, URLs, ports, retention, org/project names)
# are derived by bootstrap.sh — they are NOT here.

# --- Grafana (backend) ---
GRAFANA_ADMIN_PASSWORD=

# --- GlitchTip ---
GLITCHTIP_POSTGRES_PASSWORD=
GLITCHTIP_SECRET_KEY=
GLITCHTIP_SUPERUSER_PASSWORD=

# --- Langfuse ---
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_POSTGRES_PASSWORD=
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_REDIS_AUTH=
LANGFUSE_MINIO_ROOT_PASSWORD=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_PASSWORD=
