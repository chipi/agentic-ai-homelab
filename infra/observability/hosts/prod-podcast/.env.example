# VPS (prod-podcast) collector -> self-hosted backend on the DGX (tailnet).
# Copy to `.env` on the box (/opt/vps-observability/.env). No secrets here —
# VictoriaMetrics/VictoriaLogs ignore auth on the tailnet.
#
# Metrics -> VictoriaMetrics :8428 ; logs -> VictoriaLogs :9428 (Loki push).
# These two are the ONLY backend references for this collector (config.alloy reads
# them via sys.env — no hardcoded IP in the .alloy). Backend migration DGX → homelab
# = flip both to `homelab` (Tailscale device name; resolves tailnet-wide):
#   migration: REMOTE_WRITE_URL=http://homelab:8428/api/v1/write
#              LOGS_WRITE_URL=http://homelab:9428/insert/loki/api/v1/push
REMOTE_WRITE_URL=http://dgx-llm-1:8428/api/v1/write
LOGS_WRITE_URL=http://dgx-llm-1:9428/insert/loki/api/v1/push

# Per-deploy identity — distinct from the DGX so series don't collide.
HOMELAB_INSTANCE=prod-podcast
HOMELAB_CLUSTER=vps

# Grafana Cloud vars are unused on the tailnet (VM/VL ignore auth) but the
# config's remote_write block still reads them — leave any dummy value.
GRAFANA_CLOUD_PROM_URL=unused
GRAFANA_CLOUD_PROM_USERNAME=unused
GRAFANA_CLOUD_PROM_API_KEY=unused
