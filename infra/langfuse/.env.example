# Langfuse v3 — copy to .env (gitignored). Runs on ONE host (DGX now, Mac mini later).

# --- Bind + external URL -------------------------------------------------
# LANGFUSE_LISTEN → this host's Tailscale IP (100.x.y.z) so the UI is on the
# tailnet, never public. LANGFUSE_PORT (4000) needs its own ACL grant.
# NEXTAUTH_URL MUST match how the browser reaches the UI or auth/login breaks.
LANGFUSE_LISTEN=127.0.0.1
LANGFUSE_PORT=4000
NEXTAUTH_URL=http://127.0.0.1:4000

# --- Core secrets (generate) ---------------------------------------------
SALT=                       # openssl rand -hex 16
ENCRYPTION_KEY=             # openssl rand -hex 32   (exactly 64 hex chars)
NEXTAUTH_SECRET=            # openssl rand -hex 32

# --- Datastore creds -----------------------------------------------------
POSTGRES_PASSWORD=
# DATABASE_URL password MUST equal POSTGRES_PASSWORD:
DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/postgres
CLICKHOUSE_PASSWORD=
REDIS_AUTH=
MINIO_ROOT_PASSWORD=
# S3 access-key id defaults to 'minio' (the MinIO root user); the secret below
# MUST equal MINIO_ROOT_PASSWORD:
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=CHANGEME

# --- First-run bootstrap: org + project + API keys + admin user ----------
# Set on first boot to auto-create everything. Keep the keys — apps/proxies use
# them to send traces. (After first boot these are ignored.)
LANGFUSE_INIT_ORG_ID=homelab
LANGFUSE_INIT_ORG_NAME=homelab
LANGFUSE_INIT_PROJECT_ID=agents
LANGFUSE_INIT_PROJECT_NAME=agents
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-CHANGEME   # generate: pk-lf-$(uuidgen|tr A-Z a-z)
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-CHANGEME   # generate: sk-lf-$(uuidgen|tr A-Z a-z)
LANGFUSE_INIT_USER_EMAIL=admin@homelab.local
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=

# Langfuse's own product telemetry — off by default here.
TELEMETRY_ENABLED=false
