# Umami — copy to .env (gitignored). See ADR-0007 + README.

# Bind for the published :3001. Use this host's Tailscale IP (100.x.y.z) to keep
# the admin UI on the tailnet, or 0.0.0.0 if a tunnel/proxy fronts it.
UMAMI_LISTEN=127.0.0.1

# Secrets — generate:
UMAMI_DB_PASSWORD=          # openssl rand -hex 24
UMAMI_APP_SECRET=           # openssl rand -hex 32   (hashing/session salt)
