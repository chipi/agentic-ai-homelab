# vLLM coder-next — runtime secrets.
#
# Copy to .env (gitignored) and fill in both values.
#
# HF_TOKEN: required for gated models (Qwen3-Coder-Next-FP8 is open today,
# but pinning the token avoids surprises if licensing changes). Generate at
# https://huggingface.co/settings/tokens — read-only is sufficient.
#
# VLLM_API_KEY: the shared API key clients send via Authorization: Bearer.
# Single-operator setup — pick something memorable. Rotate by editing here
# and `docker compose up -d` (recreates the container).

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VLLM_API_KEY=buddy-is-the-king
