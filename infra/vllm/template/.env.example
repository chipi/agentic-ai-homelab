# vLLM template — runtime secrets + tunables.
#
# Copy to .env (gitignored) and fill in. Every operational value the compose
# touches is wired via ${VAR:-default} substitution, so anything below that
# you don't set falls back to the documented default.

# ─── Required ─────────────────────────────────────────────────────────
# HF_TOKEN: required for gated HuggingFace models. Generate at
# https://huggingface.co/settings/tokens (read scope is enough).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional — defaults shown in the compose ─────────────────────────
# VLLM_API_KEY: shared API key clients send via Authorization: Bearer.
# Single-operator setup; pick something memorable. Rotate by editing
# here + `docker compose up -d`.
# VLLM_API_KEY=buddy-is-the-king

# Where models live on the host. The compose mounts this 1:1 inside the
# container so HF paths resolve identically inside and outside.
# HF_HOME=/opt/llm-models/huggingface
# VLLM_CACHE_PATH=/opt/llm-models/vllm-cache

# Listening port on host AND container. Coexists with the rest of the
# homelab convention of port 9000.
# VLLM_PORT=9000
