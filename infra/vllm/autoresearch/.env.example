# vllm-autoresearch .env template — copy to .env, fill in secrets.

# HuggingFace token — required for any gated model (Qwen3 family is
# generally open, but pin this anyway so the cache layer auths
# consistently with coder-next).
HF_TOKEN=

# vLLM API key — clients (autoresearch eval harness, manual curl)
# pass this in the Authorization: Bearer header. Same key style as
# coder-next; podcast_scraper's eval scripts read VLLM_API_KEY from
# the same .env.
VLLM_API_KEY=buddy-is-the-king

# Port the autoresearch vLLM listens on. The default matches
# GPU_MODE_RESEARCH_PORT in gpu-mode-swap.sh.
VLLM_PORT=8003

# GPU memory cap. 0.75 is the GB10 unified-memory ceiling; 0.92
# OOM-crashes the host. Override only for a quieter-box eval; revert
# after.
VLLM_GPU_MEM_UTIL=0.75

# Optional: HF and vLLM caches. Defaults align with coder-next so
# downloads are shared.
HF_HOME=/opt/llm-models/huggingface
VLLM_CACHE_PATH=/opt/llm-models/vllm-cache
