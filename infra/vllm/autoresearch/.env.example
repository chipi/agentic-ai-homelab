# vllm-autoresearch .env template — copy to .env, fill in secrets.

# HuggingFace token — required for any gated model (Qwen3 family is
# generally open, but pin this anyway so the cache layer auths
# consistently with coder-next).
HF_TOKEN=

# vLLM API key — clients (autoresearch eval harness, manual curl)
# pass this in the Authorization: Bearer header. Same key style as
# coder-next; podcast_scraper's eval scripts read VLLM_API_KEY from
# the same .env.
VLLM_API_KEY=buddy-is-the-king

# Port the autoresearch vLLM listens on. The default matches
# GPU_MODE_RESEARCH_PORT in gpu-mode-swap.sh.
VLLM_PORT=8003

# GPU memory utilization — pick the profile that matches your workload.
# Full methodology + per-model recommendations + boot-time notes:
#   KV_CACHE_SIZING.md (same dir)
#
# Profile: sweep (single-request, isolated)
#   - autoresearch / eval / benchmark workloads, 1 request at a time
#   - Peak observed kv_cache_usage_perc on bf16 ≤35B models: ~1.86%
#   - Right value = weight_floor + ~0.05 margin (per-model table in
#     KV_CACHE_SIZING.md § Per-workload profiles → "sweep")
#   - 0.60 is a safe middle for ≤35B bf16 sweep; drop to per-model
#     value if you need to free more host RAM for sibling services.
VLLM_GPU_MEM_UTIL=0.60
#
# Profile: prod (concurrent / batched serving)
#   - Not measured on this homelab yet. Sample peak under
#     representative concurrent-request soak before pinning, per the
#     methodology in KV_CACHE_SIZING.md.
#   - vLLM upstream default (0.75) is the right placeholder until
#     measurement.
#   - Hard ceiling on GB10 unified memory: 0.78 (above starves the
#     host; 0.92 OOM-crashes — DO NOT use 0.92).
# VLLM_GPU_MEM_UTIL=0.75

# Optional: HF and vLLM caches. Defaults align with coder-next so
# downloads are shared.
HF_HOME=/opt/llm-models/huggingface
VLLM_CACHE_PATH=/opt/llm-models/vllm-cache
