{
  "statusLine": {
    "type": "command",
    "command": "bash \"${HOME}/.claude/plugins/cache/ponytail/ponytail/<VERSION>/hooks/ponytail-statusline.sh\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/lean-ctx hook rewrite"
          }
        ]
      },
      {
        "matcher": "Bash|bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/secrets-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/lean-ctx hook observe"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/lean-ctx hook observe"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/lean-ctx hook observe"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/lean-ctx hook observe"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "lavish-axi",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/lean-ctx hook observe"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/homebrew/bin/lean-ctx hook observe"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp"
    ],
    "allow": []
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "ponytail@ponytail": false
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true
}